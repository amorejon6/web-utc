<dcat:Distribution>
  <schema:variableMeasured>
    <schema:PropertyValue>
      <schema:name>NACIONALITAT</schema:name>
      <schema:description>Nacionalitat de les persones registrades</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Total</schema:name>
      <schema:description>Total de persones de cada país</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Dones</schema:name>
      <schema:description>Nombre de dones registrades</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Homes</schema:name>
      <schema:description>Nombre d'homes registrats</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
  </schema:variableMeasured>
</dcat:Distribution>
<dcat:Distribution>
  <schema:variableMeasured>
    <schema:PropertyValue>
      <schema:name>NACIONALIDAD</schema:name>
      <schema:description>Nombre del país o región de origen de los registros</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Total</schema:name>
      <schema:description>Total de registros asociados a la nacionalidad</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Mujeres</schema:name>
      <schema:description>Número de mujeres registradas</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Hombres</schema:name>
      <schema:description>Número de hombres registrados</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
  </schema:variableMeasured>
</dcat:Distribution>
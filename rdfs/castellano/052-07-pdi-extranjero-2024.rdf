<dcat:Distribution>
  <schema:variableMeasured>
    <schema:PropertyValue>
      <schema:name>NACIONALIDAD</schema:name>
      <schema:description>Nacionalidad de los individuos</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>TOTAL</schema:name>
      <schema:description>Total de individuos</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>CATEDRÁTICO/A DE UNIVERSIDAD</schema:name>
      <schema:description>Número de catedráticos de universidad</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>PROFES▴OR/A TITULAR DE UNIVERSIDAD</schema:name>
      <schema:description>Número de profesores titulares de universidad</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>PROFESOR/A PERMANENTE LABORAL</schema:name>
      <schema:description>Número de profesores permanentes laborales</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>PROFESOR/A AYUDANTE DOCTOR/A</schema:name>
      <schema:description>Número de profesores ayudantes doctorales</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>AYUDANTE LOU</schema:name>
      <schema:description>Número de ayudantes LOU</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>PROFESOR/A COLABORADOR/A</schema:name>
      <schema:description>Número de profesores colaboradores</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>PROFESOR/A ASOCIADO/A</schema:name>
      <schema:description>Número de profesores asociados</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>PROFESOR/A VISITANTE</schema:name>
      <schema:description>Número de profesores visitantes</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
  </schema:variableMeasured>
</dcat:Distribution>
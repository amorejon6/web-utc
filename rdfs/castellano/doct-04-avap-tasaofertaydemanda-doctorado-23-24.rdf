<dcat:Distribution>
  <schema:variableMeasured>
    <schema:PropertyValue>
      <schema:name>PROGRAMAS DE DOCTORADO</schema:name>
      <schema:description>Nombre del programa de doctorado</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Nº Plazas demandadas</schema:name>
      <schema:description>Número de plazas demandadas por los estudiantes</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Nº Plazas ofertadas</schema:name>
      <schema:description>Número de plazas ofertadas por la institución</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </schema:PropertyValue>
    <schema:PropertyValue>
      <schema:name>Tasa de oferta y demanda (%)</schema:name>
      <schema:description>Ratio entre el número de plazas ofertadas y demandadas, expresado como porcentaje</schema:description>
      <schema:valueType rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </schema:PropertyValue>
  </schema:variableMeasured>
</dcat:Distribution>